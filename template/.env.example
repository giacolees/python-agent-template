# Copy to .env and fill in values. Never commit the real .env file.

# Path to the active pipeline config (see configs/default.yaml)
{{ project_slug | upper }}_CONFIG_PATH=configs/default.yaml

# Logging level: DEBUG | INFO | WARNING | ERROR
{{ project_slug | upper }}_LOG_LEVEL=INFO

{% if include_agent_memory %}# Set to 1 to skip the shared agent-memory extraction hook for a single
# commit{% if include_agent_rules %} (see .agentrules/COLLABORATION.md §9){% endif %}. Not required.
# SKIP_AGENT_MEMORY=1
{% endif %}{% if include_agent_memory and include_compaction_memory %}
# Compaction memory: which extractor driver judges session insights
# (scripts/extractors/<name>.sh). Default: claude.
# AGENT_MEMORY_EXTRACTOR=claude

# Set to 1 to skip compaction-memory extraction for a session.
# SKIP_COMPACTION_MEMORY=1
{% endif %}
