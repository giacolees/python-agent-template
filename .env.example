# Copy to .env and fill in values. Never commit the real .env file.

# Path to the active pipeline config (see configs/default.yaml)
PYTHON_AGENT_TEMPLATE_CONFIG_PATH=configs/default.yaml

# Logging level: DEBUG | INFO | WARNING | ERROR
PYTHON_AGENT_TEMPLATE_LOG_LEVEL=INFO

# Set to 1 to skip the shared agent-memory extraction hook for a single
# commit (see .agentrules/COLLABORATION.md §9). Not required.
# SKIP_AGENT_MEMORY=1

# Compaction memory: which extractor driver judges session insights
# (scripts/extractors/<name>.sh). Default: claude.
# AGENT_MEMORY_EXTRACTOR=claude

# Set to 1 to skip compaction-memory extraction for a session.
# SKIP_COMPACTION_MEMORY=1
